
{
  "name": "Executive Consulting Theme",
  "foreground": "#1E293B",
  "background": "#F5F7FA",
  "tableAccent": "#2563EB",
  "dataColors": [
    "#2563EB",
    "#16A34A",
    "#F59E0B",
    "#DC2626",
    "#4F81BD",
    "#7C3AED",
    "#14B8A6",
    "#64748B"
  ],
  "visualStyles": {
    "*": {
      "*": {
        "title": [{
          "show": true,
          "fontSize": 16,
          "fontFamily": "Segoe UI Semibold",
          "color": {"solid": {"color": "#1E293B"}}
        }],
        "background": [{
          "show": true,
          "color": {"solid": {"color": "#FFFFFF"}},
          "transparency": 0
        }],
        "border": [{
          "show": true,
          "color": {"solid": {"color": "#D9DEE5"}}
        }]
      }
    },
    "card": {
      "*": {
        "labels": [{
          "color": {"solid": {"color": "#1E293B"}},
          "fontSize": 11
        }],
        "calloutValue": [{
          "fontSize": 30
        }]
      }
    }
  }
}
